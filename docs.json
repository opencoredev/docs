{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "OpenChat",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "index",
              "quickstart",
              "guides/architecture"
            ]
          },
          {
            "group": "Core Features",
            "icon": "sparkles",
            "pages": [
              "features/chat-experience",
              "features/model-selection",
              "features/web-search-and-reasoning",
              "features/files-and-exports",
              "features/settings-and-shortcuts"
            ]
          },
          {
            "group": "Guides",
            "icon": "book",
            "pages": [
              "guides/authentication",
              "guides/providers-and-encryption",
              "development"
            ]
          },
          {
            "group": "Self-Hosting",
            "icon": "server",
            "pages": [
              "self-hosting/overview",
              "self-hosting/environment",
              "self-hosting/docker",
              "self-hosting/vercel-convex"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Web API Routes",
            "pages": [
              "api-reference/models-endpoint",
              "api-reference/provider-credentials-endpoint",
              "api-reference/openrouter-key-endpoint",
              "api-reference/workflows-endpoints"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/opencoredev/openchat",
          "icon": "github"
        },
        {
          "anchor": "Try OpenChat",
          "href": "https://osschat.dev",
          "icon": "arrow-up-right-from-square"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/opencoredev/openchat"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Try OpenChat",
      "href": "https://osschat.dev"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/osschat",
      "github": "https://github.com/opencoredev/openchat"
    }
  },
  "mermaid": {}
}
